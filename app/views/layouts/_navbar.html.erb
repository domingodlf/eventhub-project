<nav class="navbar navbar-expand-lg bg-white border-bottom fixed-top py-3">
  <div class="container-fluid px-4 px-lg-5">
      
    <!-- Brand -->
    <%= link_to "EventHub", root_path, class: "navbar-brand fw-bold fs-3 perclas-turquoise-text" %>

    <!-- Toggler -->
    <button
      class="navbar-toggler border-0 shadow-none"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#mainNavbar"
      aria-controls="mainNavbar"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar content -->
    <div class="collapse navbar-collapse" id="mainNavbar">

      <!-- Search bar desktop -->
      <form class="d-none d-lg-flex align-items-center border rounded-pill px-2 py-1 mx-lg-4 perclas-navbar-search" role="search">
        <input
          class="form-control border-0 shadow-none"
          type="search"
          placeholder="Search events..."
          aria-label="Search events"
        >

        <span class="text-secondary px-2">|</span>

        <input
          class="form-control border-0 shadow-none"
          type="search"
          placeholder="Location"
          aria-label="Location"
        >

        <button class="btn rounded-circle ms-2 px-3 perclas-turquoise-bg perclas-turquoise-hover text-white" type="button">
          Search
        </button>
      </form>

      <!-- Links -->
      <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">
        <li class="nav-item">
          <%= link_to "Find Events", events_path, class: "nav-link fw-semibold" %>
        </li>

        <% if can?(:create, Event) %>
          <li class="nav-item">
            <%= link_to "Create Event", new_event_path, class: "nav-link fw-semibold" %>
          </li>
        <% end %>

        <li class="nav-item">
          <a class="nav-link fw-semibold" href="#contact">Contact</a>
        </li>

        <!-- Dropdown -->
        <li class="nav-item dropdown">
          <a
            class="nav-link dropdown-toggle fw-semibold"
            href="#"
            role="button"
            data-bs-toggle="dropdown"
            aria-expanded="false"
          >
            More
          </a>

          <ul class="dropdown-menu dropdown-menu-end">
            <li>
              <%= link_to "Categories", categories_path, class: "dropdown-item" %>
            </li>
            <li>
              <%= link_to "Venues", venues_path, class: "dropdown-item" %>
            </li>
            <% if can?(:index, User) %>
              <li>
                <%= link_to "Users", users_path, class: "dropdown-item" %>
              </li>
            <% end %>

            <% if user_signed_in? %>
              <li>
                <%= link_to "Registrations", registrations_path, class: "dropdown-item" %>
              </li>
            <% end %>

            <li>
              <%= link_to "Reviews", reviews_path, class: "dropdown-item" %>
            </li>
          </ul>
        </li>

        <% if user_signed_in? %>
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle text-secondary"
              href="#"
              role="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
            >
              <%= current_user.first_name %>
            </a>

            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <%= link_to "Edit Profile", edit_user_registration_path, class: "dropdown-item" %>
              </li>
            </ul>
          </li>

          <li class="nav-item">
            <%= button_to "Log out",
                destroy_user_session_path,
                method: :delete,
                class: "btn btn-sm rounded-pill px-3 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Log in", new_user_session_path, class: "nav-link fw-semibold" %>
          </li>

          <li class="nav-item">
            <%= link_to "Sign up",
                new_user_registration_path,
                class: "btn btn-sm rounded-pill px-3 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
          </li>
        <% end %>
      </ul>

      <!-- Search mobile -->
      <form class="d-lg-none mt-3" role="search">
        <input
          class="form-control mb-2"
          type="search"
          placeholder="Search events..."
          aria-label="Search events"
        >

        <input
          class="form-control mb-2"
          type="search"
          placeholder="Location"
          aria-label="Location"
        >

        <button class="btn w-100 text-white perclas-turquoise-bg perclas-turquoise-hover" type="button">
          Search
        </button>
      </form>
    </div>
  </div>
</nav>