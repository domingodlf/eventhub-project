<section class="container-fluid px-4 px-lg-5 mt-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="fw-bold mb-2">Registrations</h1>
            <p class="text-secondary mb-0">
                Browse user registrations for EventHub events.
            </p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Event</th>
                    <th>Status</th>
                    <th>Registered at</th>
                    <th>Waitlist position</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                <% @registrations.each do |registration| %>
                    <tr>
                        <td>
                            <% if can?(:read, registration.user) %>
                                <%= link_to "#{registration.user.first_name} #{registration.user.last_name}", user_path(registration.user), class: "fw-semibold text-decoration-none perclas-turquoise-text" %>
                            <% else %>
                                <span class="fw-semibold perclas-turquoise-text"><%= registration.user.first_name %> <%= registration.user.last_name %></span>
                            <% end %>
                        </td>
                        <td>
                            <%= link_to registration.event.title, event_path(registration.event), class: "text-decoration-none perclas-turquoise-text" %>
                        </td>
                        <td>
                            <span class="badge rounded-pill text-bg-light">
                                <%= registration.status.humanize %>
                            </span>
                        </td>
                        <td><%= registration.registered_at.strftime("%B %d, %Y %I:%M %p") if registration.registered_at %></td>
                        <td><%= registration.waitlist_position || "—" %></td>
                        <td class="text-end">
                            <%= link_to "View registration", registration_path(registration), class: "btn btn-sm rounded-pill px-3 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
                        </td>
                    </tr>
                <% end %>
            </tbody>
        </table>
    </div>

</section>