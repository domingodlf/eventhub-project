<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-lg-5">
          <h2 class="fw-bold mb-2">Create your account</h2>
          <p class="text-secondary mb-4">Join EventHub to create events, register, and review activities.</p>

          <%= form_for(resource, as: resource_name, url: user_registration_path) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <div class="mb-3">
              <%= f.label :first_name, class: "form-label fw-semibold" %>
              <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name", class: "form-control rounded-3", placeholder: "Enter your first name" %>
            </div>

            <div class="mb-3">
              <%= f.label :last_name, class: "form-label fw-semibold" %>
              <%= f.text_field :last_name, autocomplete: "family-name", class: "form-control rounded-3", placeholder: "Enter your last name" %>
            </div>

            <div class="mb-3">
              <%= f.label :email, class: "form-label fw-semibold" %>
              <%= f.email_field :email, autocomplete: "email", class: "form-control rounded-3", placeholder: "you@example.com" %>
            </div>

            <div class="mb-3">
              <%= f.label :password, class: "form-label fw-semibold" %>
              <% if @minimum_password_length %>
                <div class="form-text mb-1"><%= @minimum_password_length %> characters minimum</div>
              <% end %>
              <%= f.password_field :password, autocomplete: "new-password", class: "form-control rounded-3", placeholder: "Create a password" %>
            </div>

            <div class="mb-4">
              <%= f.label :password_confirmation, class: "form-label fw-semibold" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control rounded-3", placeholder: "Repeat your password" %>
            </div>

            <%= f.submit "Sign up", class: "btn w-100 rounded-pill text-white perclas-turquoise-bg perclas-turquoise-hover" %>
          <% end %>

          <div class="mt-4">
            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>