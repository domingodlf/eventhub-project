<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-lg-5">
          <h2 class="fw-bold mb-2">Edit account</h2>
          <p class="text-secondary mb-4">Update your EventHub profile information.</p>

          <%= form_for(resource, as: resource_name, url: user_registration_path, html: { method: :put }) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= f.label :first_name, class: "form-label fw-semibold" %>
                <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name", class: "form-control rounded-3" %>
              </div>

              <div class="col-md-6 mb-3">
                <%= f.label :last_name, class: "form-label fw-semibold" %>
                <%= f.text_field :last_name, autocomplete: "family-name", class: "form-control rounded-3" %>
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :email, class: "form-label fw-semibold" %>
              <%= f.email_field :email, autocomplete: "email", class: "form-control rounded-3" %>
            </div>

            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <div class="alert alert-info rounded-4">
                Currently waiting confirmation for: <%= resource.unconfirmed_email %>
              </div>
            <% end %>

            <div class="mb-3">
              <%= f.label :password, class: "form-label fw-semibold" %>
              <div class="form-text mb-1">Leave blank if you do not want to change it.</div>
              <% if @minimum_password_length %>
                <div class="form-text mb-1"><%= @minimum_password_length %> characters minimum</div>
              <% end %>
              <%= f.password_field :password, autocomplete: "new-password", class: "form-control rounded-3" %>
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation, class: "form-label fw-semibold" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control rounded-3" %>
            </div>

            <div class="mb-4">
              <%= f.label :current_password, class: "form-label fw-semibold" %>
              <div class="form-text mb-1">We need your current password to confirm your changes.</div>
              <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control rounded-3" %>
            </div>

            <div class="d-flex gap-2 flex-wrap">
              <%= f.submit "Update account", class: "btn rounded-pill text-white perclas-turquoise-bg perclas-turquoise-hover px-4" %>
              <%= link_to "Back to EventHub", root_path, class: "btn btn-outline-secondary rounded-pill px-4" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>