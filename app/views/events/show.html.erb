<section class="container-fluid px-4 px-lg-5 mt-5">

    <div class="card border-0 shadow-sm rounded-5 mb-5">
        <div class="card-body p-4 p-lg-5">
            <p class="text-secondary fw-semibold mb-2">Event</p>

            <h1 class="fw-bold mb-3">
                <%= @event.title %>
            </h1>

            <div class="lead text-secondary mb-4">
                <%= @event.description %>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-12 col-md-4">
                    <p class="text-secondary mb-1">Category</p>
                    <p class="fw-semibold mb-0">
                        <%= link_to @event.category.name, category_path(@event.category), class: "text-decoration-none perclas-turquoise-text" %>
                    </p>
                </div>

                <div class="col-12 col-md-4">
                    <p class="text-secondary mb-1">Venue</p>
                    <p class="fw-semibold mb-0">
                        <%= link_to @event.venue.name, venue_path(@event.venue), class: "text-decoration-none perclas-turquoise-text" %>
                    </p>
                </div>

                <div class="col-12 col-md-4">
                    <p class="text-secondary mb-1">Organizer</p>
                    <p class="fw-semibold mb-0">
                        <%= link_to "#{@event.organizer.first_name} #{@event.organizer.last_name}", user_path(@event.organizer), class: "text-decoration-none perclas-turquoise-text" %>
                    </p>
                </div>

                <div class="col-12 col-md-4">
                    <p class="text-secondary mb-1">Status</p>
                    <p class="fw-semibold mb-0">
                        <span class="badge rounded-pill text-bg-light">
                            <%= @event.status.humanize %>
                        </span>
                    </p>
                </div>

                <div class="col-12 col-md-4">
                    <p class="text-secondary mb-1">Starts</p>
                    <p class="fw-semibold mb-0">
                        <%= @event.start_time.strftime("%B %d, %Y %I:%M %p") if @event.start_time %>
                    </p>
                </div>

                <div class="col-12 col-md-4">
                    <p class="text-secondary mb-1">Ends</p>
                    <p class="fw-semibold mb-0">
                        <%= @event.end_time.strftime("%B %d, %Y %I:%M %p") if @event.end_time %>
                    </p>
                </div>

                <div class="col-12 col-md-4">
                    <p class="text-secondary mb-1">Max attendees</p>
                    <p class="fw-semibold mb-0"><%= @event.max_attendees %></p>
                </div>

                <div class="col-12 col-md-4">
                    <p class="text-secondary mb-1">Confirmed registrations</p>
                    <p class="fw-semibold mb-0"><%= @event.confirmed_registrations_count %></p>
                </div>

                <div class="col-12 col-md-4">
                    <p class="text-secondary mb-1">Available spots</p>
                    <p class="fw-semibold mb-0"><%= @event.available_spots %></p>
                </div>

                <div class="col-12 col-md-4">
                    <p class="text-secondary mb-1">Waitlisted</p>
                    <p class="fw-semibold mb-0"><%= @event.waitlisted_registrations_count %></p>
                </div>

                <div class="col-12 col-md-4">
                    <p class="text-secondary mb-1">Reviews</p>
                    <p class="fw-semibold mb-0"><%= @event.reviews.count %></p>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <%= link_to "Back to events", events_path, class: "btn btn-outline-secondary rounded-pill px-4" %>

                <%= link_to "Edit Event", edit_event_path(@event), class: "btn rounded-pill px-4 text-white perclas-turquoise-bg perclas-turquoise-hover" %>

                <% if @event.draft? %>
                    <%= button_to "Publish Event", publish_event_path(@event),
                        method: :patch,
                        data: { turbo_confirm: "Are you sure you want to publish this event?" },
                        class: "btn btn-outline-success rounded-pill px-4" %>
                <% end %>

                <% if @event.draft? || @event.published? %>
                    <%= button_to "Cancel Event", event_path(@event),
                        method: :delete,
                        data: { turbo_confirm: "Are you sure you want to cancel this event?" },
                        class: "btn btn-outline-danger rounded-pill px-4" %>
                <% end %>
            </div>
        </div>
    </div>

    <div class="mb-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
            <div>
                <h2 class="fw-bold mb-2">Registrations</h2>
                <p class="text-secondary mb-0">
                    Users registered for this event.
                </p>
            </div>
        </div>

        <% if @event.published? %>
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-2">Register for this event</h5>

                    <p class="text-secondary mb-3">
                        Select a user to register. If there are no available spots, the user will be added to the waitlist.
                    </p>

                    <%= form_with model: @registration, url: registrations_path, class: "row g-3 align-items-end" do |form| %>
                        <%= form.hidden_field :event_id, value: @event.id %>

                        <div class="col-12 col-md-8">
                            <%= form.label :user_id, "User", class: "form-label fw-semibold" %>
                            <%= form.select :user_id,
                                @users.map { |user| ["#{user.first_name} #{user.last_name} (#{user.email})", user.id] },
                                { prompt: "Select a user" },
                                { class: "form-select", required: true } %>
                        </div>

                        <div class="col-12 col-md-4">
                            <%= form.submit "Register", class: "btn w-100 rounded-pill px-4 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
                        </div>
                    <% end %>
                </div>
            </div>
        <% else %>
            <div class="alert alert-light border rounded-4 mb-4">
                Registration is available only for published events.
            </div>
        <% end %>

        <% if @registrations.any? %>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Status</th>
                            <th>Registered at</th>
                            <th>Waitlist position</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% @registrations.each do |registration| %>
                            <tr>
                                <td>
                                    <%= link_to "#{registration.user.first_name} #{registration.user.last_name}", user_path(registration.user), class: "fw-semibold text-decoration-none perclas-turquoise-text" %>
                                </td>
                                <td>
                                    <span class="badge rounded-pill text-bg-light">
                                        <%= registration.status.humanize %>
                                    </span>
                                </td>
                                <td><%= registration.registered_at.strftime("%B %d, %Y %I:%M %p") if registration.registered_at %></td>
                                <td><%= registration.waitlist_position || "—" %></td>
                                <td>
                                    <% if @event.published? && !registration.cancelled? %>
                                        <%= button_to "Cancel registration", cancel_registration_path(registration),
                                            method: :patch,
                                            data: { turbo_confirm: "Are you sure you want to cancel this registration?" },
                                            class: "btn btn-outline-danger btn-sm rounded-pill px-3" %>
                                    <% else %>
                                        <span class="text-secondary">—</span>
                                    <% end %>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        <% else %>
            <div class="alert alert-light border rounded-4">
                There are no registrations for this event yet.
            </div>
        <% end %>
    </div>

    <div>
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
            <div>
                <h2 class="fw-bold mb-2">Reviews</h2>
                <p class="text-secondary mb-0">
                    Reviews written for this event.
                </p>
            </div>
        </div>

        <% if @event.completed? %>
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-2">Write a review</h5>

                    <p class="text-secondary mb-3">
                        Select a user who attended this completed event and write a review.
                    </p>

                    <%= form_with model: @review, url: reviews_path, class: "row g-3" do |form| %>
                        <%= form.hidden_field :event_id, value: @event.id %>

                        <div class="col-12 col-md-6">
                            <%= form.label :user_id, "User", class: "form-label fw-semibold" %>
                            <%= form.select :user_id,
                                @users.map { |user| ["#{user.first_name} #{user.last_name} (#{user.email})", user.id] },
                                { prompt: "Select a user" },
                                { class: "form-select", required: true } %>
                        </div>

                        <div class="col-12 col-md-6">
                            <%= form.label :rating, "Rating", class: "form-label fw-semibold" %>
                            <%= form.number_field :rating,
                                class: "form-control",
                                min: 1,
                                max: 5,
                                required: true,
                                placeholder: "Rate from 1 to 5" %>
                        </div>

                        <div class="col-12">
                            <%= form.label :comment, "Comment", class: "form-label fw-semibold" %>
                            <%= form.text_area :comment,
                                class: "form-control",
                                rows: 4,
                                required: true,
                                placeholder: "Write your review" %>
                        </div>

                        <div class="col-12">
                            <%= form.submit "Submit review", class: "btn rounded-pill px-4 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
                        </div>
                    <% end %>
                </div>
            </div>
        <% else %>
            <div class="alert alert-light border rounded-4 mb-4">
                Reviews are available only for completed events.
            </div>
        <% end %>

        <% if @reviews.any? %>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Rating</th>
                            <th>Comment</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% @reviews.each do |review| %>
                            <tr>
                                <td>
                                    <%= link_to "#{review.user.first_name} #{review.user.last_name}", user_path(review.user), class: "fw-semibold text-decoration-none perclas-turquoise-text" %>
                                </td>
                                <td><%= review.rating %> / 5</td>
                                <td><%= review.comment %></td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        <% else %>
            <div class="alert alert-light border rounded-4">
                There are no reviews for this event yet.
            </div>
        <% end %>
    </div>

</section>