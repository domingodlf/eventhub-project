<% if event.errors.any? %>
    <div class="alert alert-danger rounded-4 mb-4">
        <h5 class="fw-bold mb-2">
            <%= pluralize(event.errors.count, "error") %> prevented this event from being saved:
        </h5>

        <ul class="mb-0">
            <% event.errors.full_messages.each do |message| %>
                <li><%= message %></li>
            <% end %>
        </ul>
    </div>
<% end %>

<%= form_with model: event do |form| %>
    <div class="mb-3">
        <%= form.label :title, class: "form-label fw-semibold" %>
        <%= form.text_field :title, class: "form-control", placeholder: "Example: Study Session", required: true %>
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-4">
            <%= form.label :organizer_id, "Organizer", class: "form-label fw-semibold" %>
            <%= form.collection_select :organizer_id, @users, :id, :email, { prompt: "Select an organizer" }, { class: "form-select", required: true } %>
        </div>

        <div class="col-12 col-md-4">
            <%= form.label :category_id, "Category", class: "form-label fw-semibold" %>
            <%= form.collection_select :category_id, @categories, :id, :name, { prompt: "Select a category" }, { class: "form-select", required: true } %>
        </div>

        <div class="col-12 col-md-4">
            <%= form.label :venue_id, "Venue", class: "form-label fw-semibold" %>
            <%= form.collection_select :venue_id, @venues, :id, :name, { prompt: "Select a venue" }, { class: "form-select", required: true } %>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-12 col-md-4">
            <%= form.label :start_time, class: "form-label fw-semibold" %>
            <%= form.datetime_field :start_time, class: "form-control", required: true %>
        </div>

        <div class="col-12 col-md-4">
            <%= form.label :end_time, class: "form-label fw-semibold" %>
            <%= form.datetime_field :end_time, class: "form-control", required: true %>
        </div>

        <div class="col-12 col-md-4">
            <%= form.label :max_attendees, class: "form-label fw-semibold" %>
            <%= form.number_field :max_attendees, class: "form-control", placeholder: "Example: 40", required: true, min: 1 %>
        </div>
    </div>

    <div class="mt-4 mb-4">
        <%= form.label :description, class: "form-label fw-semibold" %>
        <%= form.rich_text_area :description, class: "form-control", required: true %>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <%= form.submit class: "btn rounded-pill px-4 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
        <%= link_to "Cancel", events_path, class: "btn btn-outline-secondary rounded-pill px-4" %>
    </div>
<% end %>