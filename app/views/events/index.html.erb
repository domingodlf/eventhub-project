<section class="container-fluid px-4 px-lg-5 mt-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="fw-bold mb-2">Events</h1>
            <p class="text-secondary mb-0">
                Browse events available on EventHub.
            </p>
        </div>

        <% if can?(:create, Event) %>
            <%= link_to "New Event", new_event_path, class: "btn rounded-pill px-4 mt-3 mt-md-0 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
        <% end %>
    </div>

    <div class="row g-4">
        <% @events.each do |event| %>
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 d-flex flex-column">

                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h4 class="fw-bold mb-0 me-3">
                                <%= link_to event.title, event_path(event), class: "text-decoration-none perclas-turquoise-text" %>
                            </h4>

                            <span class="badge rounded-pill text-bg-light">
                                <%= event.status.humanize %>
                            </span>
                        </div>

                        <p class="text-secondary mb-4">
                            <%= truncate(event.description.to_plain_text, length: 120) %>
                        </p>

                        <div class="mb-3">
                            <p class="mb-2">
                                <span class="fw-semibold">Category:</span>
                                <%= link_to event.category.name, category_path(event.category), class: "text-decoration-none perclas-turquoise-text" %>
                            </p>

                            <p class="mb-2">
                                <span class="fw-semibold">Venue:</span>
                                <%= link_to event.venue.name, venue_path(event.venue), class: "text-decoration-none perclas-turquoise-text" %>
                            </p>

                            <p class="mb-2">
                                <span class="fw-semibold">Organizer:</span>
                                <% if can?(:read, event.organizer) %>
                                    <%= link_to "#{event.organizer.first_name} #{event.organizer.last_name}", user_path(event.organizer), class: "text-decoration-none perclas-turquoise-text" %>
                                <% else %>
                                    <span class="perclas-turquoise-text"><%= event.organizer.first_name %> <%= event.organizer.last_name %></span>
                                <% end %>
                            </p>

                            <p class="mb-2">
                                <span class="fw-semibold">Starts:</span>
                                <%= event.start_time.strftime("%B %d, %Y %I:%M %p") if event.start_time %>
                            </p>

                            <p class="mb-0">
                                <span class="fw-semibold">Max attendees:</span>
                                <%= event.max_attendees %>
                            </p>
                        </div>

                        <div class="mt-auto pt-3">
                            <%= link_to "View event", event_path(event), class: "btn rounded-pill px-4 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
                        </div>

                    </div>
                </div>
            </div>
        <% end %>
    </div>

</section>