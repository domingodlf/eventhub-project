<section class="container-fluid px-4 px-lg-5 mt-5">

    <div class="card border-0 shadow-sm rounded-5 mb-5">
        <div class="card-body p-4 p-lg-5">
            <p class="text-secondary fw-semibold mb-2">Category</p>

            <h1 class="fw-bold mb-3">
                <%= @category.name %>
            </h1>

            <p class="lead text-secondary mb-4">
                <%= @category.description %>
            </p>

            <div class="d-flex flex-wrap gap-2">
                <%= link_to "Back to categories", categories_path, class: "btn btn-outline-secondary rounded-pill px-4" %>

                <%= link_to "Edit Category", edit_category_path(@category), class: "btn rounded-pill px-4 text-white perclas-turquoise-bg perclas-turquoise-hover" %>

                <%= button_to "Delete Category", category_path(@category),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure you want to delete this category?" },
                    class: "btn btn-outline-danger rounded-pill px-4" %>
            </div>
        </div>
    </div>

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-2">Events in this category</h2>
            <p class="text-secondary mb-0">
                Browse events associated with <%= @category.name %>.
            </p>
        </div>
    </div>

    <% if @category.events.any? %>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Status</th>
                        <th>Starts</th>
                        <th>Ends</th>
                        <th>Max attendees</th>
                    </tr>
                </thead>

                <tbody>
                    <% @category.events.each do |event| %>
                        <tr>
                            <td>
                                <%= link_to event.title, event_path(event), class: "fw-semibold text-decoration-none perclas-turquoise-text" %>
                            </td>
                            <td>
                                <span class="badge rounded-pill text-bg-light">
                                    <%= event.status.humanize %>
                                </span>
                            </td>
                            <td><%= event.start_time.strftime("%B %d, %Y %I:%M %p") if event.start_time %></td>
                            <td><%= event.end_time.strftime("%B %d, %Y %I:%M %p") if event.end_time %></td>
                            <td><%= event.max_attendees %></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    <% else %>
        <div class="alert alert-light border rounded-4">
            There are no events in this category yet.
        </div>
    <% end %>

</section>