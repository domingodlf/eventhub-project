<section class="container-fluid px-4 px-lg-5 mt-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="fw-bold mb-2">Categories</h1>
            <p class="text-secondary mb-0">
                Explore the different types of events available on EventHub.
            </p>
        </div>

        <% if can?(:create, Category) %>
            <%= link_to "New Category", new_category_path, class: "btn rounded-pill px-4 mt-3 mt-md-0 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
        <% end %>
    </div>

    <div class="row g-4">
        <% @categories.each do |category| %>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-3">
                            <%= link_to category.name, category_path(category), class: "text-decoration-none perclas-turquoise-text" %>
                        </h4>

                        <p class="text-secondary mb-4">
                            <%= category.description %>
                        </p>

                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge rounded-pill text-bg-light">
                                <%= pluralize(category.events.count, "event") %>
                            </span>

                            <%= link_to "View category", category_path(category), class: "btn btn-sm rounded-pill px-3 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
                        </div>
                    </div>
                </div>
            </div>
        <% end %>
    </div>

</section>