<% if category.errors.any? %>
    <div class="alert alert-danger rounded-4 mb-4">
        <h5 class="fw-bold mb-2">
            <%= pluralize(category.errors.count, "error") %> prevented this category from being saved:
        </h5>

        <ul class="mb-0">
            <% category.errors.full_messages.each do |message| %>
                <li><%= message %></li>
            <% end %>
        </ul>
    </div>
<% end %>

<%= form_with model: category do |form| %>
    <div class="mb-3">
        <%= form.label :name, class: "form-label fw-semibold" %>
        <%= form.text_field :name, class: "form-control", placeholder: "Example: Sports", required: true %>
    </div>

    <div class="mb-4">
        <%= form.label :description, class: "form-label fw-semibold" %>
        <%= form.text_area :description, class: "form-control", rows: 4, placeholder: "Describe this category", required: true %>
    </div>

    <div class="d-flex gap-2">
        <%= form.submit class: "btn rounded-pill px-4 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
        <%= link_to "Cancel", categories_path, class: "btn btn-outline-secondary rounded-pill px-4" %>
    </div>
<% end %>