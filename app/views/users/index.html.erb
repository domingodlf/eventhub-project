<section class="container-fluid px-4 px-lg-5 mt-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="fw-bold mb-2">Users</h1>
            <p class="text-secondary mb-0">
                Browse EventHub users and their activity.
            </p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Organized events</th>
                    <th>Registrations</th>
                    <th>Reviews</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                <% @users.each do |user| %>
                    <tr>
                        <td>
                            <%= link_to "#{user.first_name} #{user.last_name}", user_path(user), class: "fw-semibold text-decoration-none perclas-turquoise-text" %>
                        </td>
                        <td><%= user.email %></td>
                        <td>
                            <span class="badge rounded-pill text-bg-light">
                                <%= user.role.humanize %>
                            </span>
                        </td>
                        <td><%= user.organized_events.count %></td>
                        <td><%= user.registrations.count %></td>
                        <td><%= user.reviews.count %></td>
                        <td class="text-end">
                            <%= link_to "View user", user_path(user), class: "btn btn-sm rounded-pill px-3 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
                        </td>
                    </tr>
                <% end %>
            </tbody>
        </table>
    </div>

</section>