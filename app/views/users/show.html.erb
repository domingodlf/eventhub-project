<section class="container-fluid px-4 px-lg-5 mt-5">

    <div class="card border-0 shadow-sm rounded-5 mb-5">
        <div class="card-body p-4 p-lg-5">
            <p class="text-secondary fw-semibold mb-2">User</p>

            <h1 class="fw-bold mb-3">
                <%= @user.first_name %> <%= @user.last_name %>
            </h1>

            <div class="row g-4 mb-4">
                <div class="col-12 col-md-6">
                    <p class="text-secondary mb-1">Email</p>
                    <p class="fw-semibold mb-0"><%= @user.email %></p>
                </div>

                <div class="col-12 col-md-6">
                    <p class="text-secondary mb-1">Role</p>
                    <p class="fw-semibold mb-0"><%= @user.role.humanize %></p>
                </div>
            </div>

            <%= link_to "Back to users", users_path, class: "btn rounded-pill px-4 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
        </div>
    </div>

    <div class="mb-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
            <div>
                <h2 class="fw-bold mb-2">Organized events</h2>
                <p class="text-secondary mb-0">
                    Events created or organized by this user.
                </p>
            </div>
        </div>

        <% if @user.organized_events.any? %>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Event</th>
                            <th>Status</th>
                            <th>Starts</th>
                            <th>Ends</th>
                            <th>Max attendees</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% @user.organized_events.each do |event| %>
                            <tr>
                                <td>
                                    <%= link_to event.title, event_path(event), class: "fw-semibold text-decoration-none perclas-turquoise-text" %>
                                </td>
                                <td>
                                    <span class="badge rounded-pill text-bg-light">
                                        <%= event.status.humanize %>
                                    </span>
                                </td>
                                <td><%= event.start_time.strftime("%B %d, %Y %I:%M %p") if event.start_time %></td>
                                <td><%= event.end_time.strftime("%B %d, %Y %I:%M %p") if event.end_time %></td>
                                <td><%= event.max_attendees %></td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        <% else %>
            <div class="alert alert-light border rounded-4">
                This user has not organized any events yet.
            </div>
        <% end %>
    </div>

    <div class="mb-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
            <div>
                <h2 class="fw-bold mb-2">Registrations</h2>
                <p class="text-secondary mb-0">
                    Events this user has registered for.
                </p>
            </div>
        </div>

        <% if @user.registrations.any? %>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Event</th>
                            <th>Status</th>
                            <th>Registered at</th>
                            <th>Waitlist position</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% @user.registrations.each do |registration| %>
                            <tr>
                                <td>
                                    <%= link_to registration.event.title, event_path(registration.event), class: "fw-semibold text-decoration-none perclas-turquoise-text" %>
                                </td>
                                <td>
                                    <span class="badge rounded-pill text-bg-light">
                                        <%= registration.status.humanize %>
                                    </span>
                                </td>
                                <td><%= registration.registered_at.strftime("%B %d, %Y %I:%M %p") if registration.registered_at %></td>
                                <td><%= registration.waitlist_position || "—" %></td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        <% else %>
            <div class="alert alert-light border rounded-4">
                This user has no registrations yet.
            </div>
        <% end %>
    </div>

    <div>
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
            <div>
                <h2 class="fw-bold mb-2">Reviews</h2>
                <p class="text-secondary mb-0">
                    Reviews written by this user.
                </p>
            </div>
        </div>

        <% if @user.reviews.any? %>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Event</th>
                            <th>Rating</th>
                            <th>Comment</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% @user.reviews.each do |review| %>
                            <tr>
                                <td>
                                    <%= link_to review.event.title, event_path(review.event), class: "fw-semibold text-decoration-none perclas-turquoise-text" %>
                                </td>
                                <td><%= review.rating %> / 5</td>
                                <td><%= review.comment %></td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        <% else %>
            <div class="alert alert-light border rounded-4">
                This user has not written any reviews yet.
            </div>
        <% end %>
    </div>

</section>