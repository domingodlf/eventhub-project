<section class="container-fluid px-4 px-lg-5 mt-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="fw-bold mb-2">Reviews</h1>
            <p class="text-secondary mb-0">
                Browse user reviews for completed EventHub events.
            </p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Event</th>
                    <th>Rating</th>
                    <th>Comment</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                <% @reviews.each do |review| %>
                    <tr>
                        <td>
                            <%= link_to "#{review.user.first_name} #{review.user.last_name}", user_path(review.user), class: "fw-semibold text-decoration-none perclas-turquoise-text" %>
                        </td>
                        <td>
                            <%= link_to review.event.title, event_path(review.event), class: "text-decoration-none perclas-turquoise-text" %>
                        </td>
                        <td>
                            <span class="badge rounded-pill text-bg-light">
                                <%= review.rating %> / 5
                            </span>
                        </td>
                        <td><%= truncate(review.comment, length: 90) %></td>
                        <td class="text-end">
                            <%= link_to "View review", review_path(review), class: "btn btn-sm rounded-pill px-3 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
                        </td>
                    </tr>
                <% end %>
            </tbody>
        </table>
    </div>

</section>