<% if venue.errors.any? %>
    <div class="alert alert-danger rounded-4 mb-4">
        <h5 class="fw-bold mb-2">
            <%= pluralize(venue.errors.count, "error") %> prevented this venue from being saved:
        </h5>

        <ul class="mb-0">
            <% venue.errors.full_messages.each do |message| %>
                <li><%= message %></li>
            <% end %>
        </ul>
    </div>
<% end %>

<%= form_with model: venue do |form| %>
    <div class="mb-3">
        <%= form.label :name, class: "form-label fw-semibold" %>
        <%= form.text_field :name, class: "form-control", placeholder: "Example: Main Auditorium", required: true %>
    </div>

    <div class="mb-3">
        <%= form.label :building, class: "form-label fw-semibold" %>
        <%= form.text_field :building, class: "form-control", placeholder: "Example: Engineering Building", required: true %>
    </div>

    <div class="mb-3">
        <%= form.label :address, class: "form-label fw-semibold" %>
        <%= form.text_field :address, class: "form-control", placeholder: "Example: Campus Central", required: true %>
    </div>

    <div class="mb-4">
        <%= form.label :capacity, class: "form-label fw-semibold" %>
        <%= form.number_field :capacity, class: "form-control", placeholder: "Example: 80", required: true, min: 1 %>
    </div>

    <div class="d-flex gap-2">
        <%= form.submit class: "btn rounded-pill px-4 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
        <%= link_to "Cancel", venues_path, class: "btn btn-outline-secondary rounded-pill px-4" %>
    </div>
<% end %>