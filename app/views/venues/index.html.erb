<section class="container-fluid px-4 px-lg-5 mt-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="fw-bold mb-2">Venues</h1>
            <p class="text-secondary mb-0">
                Explore the places where EventHub activities take place.
            </p>
        </div>

        <%= link_to "New Venue", new_venue_path, class: "btn rounded-pill px-4 mt-3 mt-md-0 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Venue</th>
                    <th>Building</th>
                    <th>Address</th>
                    <th>Capacity</th>
                    <th>Events</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                <% @venues.each do |venue| %>
                    <tr>
                        <td>
                            <%= link_to venue.name, venue_path(venue), class: "fw-semibold text-decoration-none perclas-turquoise-text" %>
                        </td>
                        <td><%= venue.building %></td>
                        <td><%= venue.address %></td>
                        <td><%= venue.capacity %></td>
                        <td>
                            <span class="badge rounded-pill text-bg-light">
                                <%= pluralize(venue.events.count, "event") %>
                            </span>
                        </td>
                        <td class="text-end">
                            <%= link_to "View venue", venue_path(venue), class: "btn btn-sm rounded-pill px-3 text-white perclas-turquoise-bg perclas-turquoise-hover" %>
                        </td>
                    </tr>
                <% end %>
            </tbody>
        </table>
    </div>

</section>